# ===================================
# AI Document Analyzer — Configuração
# ===================================

# [OBRIGATÓRIO] Chave da API do Google Gemini
# Obtenha em: https://aistudio.google.com/apikey
GEMINI_API_KEY="SUA_CHAVE_DE_API_GEMINI_AQUI"

# [OPCIONAL] Modelo do Gemini (padrão: gemini-2.5-flash)
# GEMINI_MODEL="gemini-2.5-flash"

# [OPCIONAL] Tamanho máximo de arquivo em MB (padrão: 50)
# MAX_FILE_SIZE_MB=50

# [OPCIONAL] Configuração de retry da API
# RETRY_ATTEMPTS=3
# RETRY_MIN_WAIT=2
# RETRY_MAX_WAIT=30

# [OPCIONAL] Nível de log (DEBUG, INFO, WARNING, ERROR)
# LOG_LEVEL=INFO
